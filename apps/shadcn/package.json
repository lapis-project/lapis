{
	"name": "@lapis/shadcn",
	"private": true,
	"license": "MIT",
	"type": "module",
	"main": "./nuxt.config.ts",
	"engines": {
		"node": ">=24.11.0",
		"pnpm": ">=11.4"
	},
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev"
	},
	"dependencies": {
		"@acdh-oeaw/lib": "^1.0.5",
		"@fontsource-variable/inter": "^5.2.8",
		"@lucide/vue": "catalog:",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/vue-table": "^8.21.3",
		"@vee-validate/zod": "^4.15.1",
		"@vueuse/core": "^14.2.1",
		"@vueuse/nuxt": "^14.2.1",
		"@vueuse/shared": "^14.2.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cva": "1.0.0-beta.1",
		"nuxt": "catalog:",
		"reka-ui": "^2.8.2",
		"shadcn-nuxt": "^2.4.3",
		"tailwind-merge": "^3.5.0",
		"tailwindcss-animate": "^1.0.7",
		"tw-animate-css": "^1.4.0",
		"vaul-vue": "^0.4.1",
		"vee-validate": "^4.15.1",
		"vue": "catalog:",
		"vue-router": "^5.0.3",
		"vue-sonner": "^2.0.9",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@acdh-oeaw/eslint-config": "^2.0.13",
		"@acdh-oeaw/eslint-config-nuxt": "^2.0.19",
		"@acdh-oeaw/eslint-config-vue": "^2.0.17",
		"@acdh-oeaw/stylelint-config": "^3.0.3",
		"@acdh-oeaw/tsconfig": "^1.5.1",
		"@nuxt/eslint": "catalog:",
		"@types/node": "^25.6.0",
		"eslint": "catalog:",
		"eslint-config-flat-gitignore": "^2.1.0",
		"stylelint": "^17.4.0",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"typescript-eslint": "^8.56.1",
		"vite": "catalog:",
		"vue-tsc": "^3.2.5"
	},
	"browserslist": {
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		],
		"production": [
			">=0.75%",
			"not dead",
			"not op_mini all"
		]
	},
	"lint-staged": {
		"*.@(vue)": [
			"eslint --cache --fix",
			"stylelint --cache --fix --allow-empty-input",
			"prettier --cache --cache-location ./.prettiercache --write"
		],
		"*.@(js|ts)": [
			"eslint --cache --fix",
			"prettier --cache --cache-location ./.prettiercache --write"
		],
		"*.@(css)": [
			"stylelint --cache --fix",
			"prettier --cache --cache-location ./.prettiercache --write"
		],
		"*.!(css|js|ts|vue),!./@(content|public)/**": "prettier --cache --cache-location ./.prettiercache --ignore-unknown --write"
	},
	"stylelint": {
		"extends": "@acdh-oeaw/stylelint-config"
	}
}
