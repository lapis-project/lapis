{
	"name": "lapis",
	"description": "Monorepo for Lapis",
	"author": "Kilian Kukelka",
	"type": "module",
	"license": "MIT",
	"packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=24.11.0",
			"onFail": "download"
		}
	},
	"engines": {
		"runtime": {
			"name": "node",
			"version": ">=24.11.0",
			"onFail": "download"
		}
	},
	"scripts": {
		"prepare": "run-s setup",
		"setup": "is-ci || simple-git-hooks",
		"format:check": "prettier . --cache --check",
		"build:backend": "pnpm -F backend build",
		"build:corpus": "pnpm -F corpus build",
		"build:lexat": "pnpm -F lexat build",
		"build:lexvad": "pnpm -F lexvad build",
		"build:lioe": "pnpm -F lioe build",
		"build:shadcn": "pnpm -F shadcn build",
		"build:ui": "pnpm -F ui build",
		"build:wboe": "pnpm -F wboe build",
		"clean:workspace": "node ./scripts/clean-workspace.mjs",
		"clean:workspace:dry": "node ./scripts/clean-workspace.mjs --dry-run",
		"dev:backend": "pnpm -F backend dev",
		"dev:corpus": "pnpm -F corpus dev",
		"dev:lexat": "pnpm -F lexat dev",
		"dev:lexvad": "pnpm -F lexvad dev",
		"dev:lioe": "pnpm -F lioe dev",
		"dev:wboe": "pnpm -F wboe dev",
		"dev-test:backend": "pnpm -F backend dev-test",
		"dev-local:corpus": "pnpm -F corpus dev-local",
		"dev-local:lexat": "pnpm -F lexat dev-local",
		"dev-local:lexvad": "pnpm -F lexvad dev-local",
		"dev-local:lioe": "pnpm -F lioe dev-local",
		"dev-local:wboe": "pnpm -F wboe dev-local",
		"lint:check": "run-p --continue-on-error \"lint:*:check\"",
		"lint:fix": "run-p --continue-on-error \"lint:*:fix\"",
		"lint:code:check": "eslint . --cache",
		"lint:code:fix": "pnpm run lint:code:check --fix",
		"lint:styles:check": "stylelint \"./**/*.@(css|vue)\" --cache --ignore-path ./.gitignore",
		"lint:styles:fix": "pnpm run lint:styles:check --fix",
		"start:backend": "pnpm -F backend start",
		"start:corpus": "pnpm -F corpus start",
		"start:lexat": "pnpm -F lexat start",
		"start:lexvad": "pnpm -F lexvad start",
		"start:lioe": "pnpm -F lioe start",
		"start:wboe": "pnpm -F wboe start"
	},
	"devDependencies": {
		"@acdh-oeaw/commitlint-config": "^3.0.0",
		"@acdh-oeaw/prettier-config": "^2.0.1",
		"@commitlint/cli": "^20.5.0",
		"@types/node": "^25.6.0",
		"is-ci": "^4.1.0",
		"lint-staged": "^16.4.0",
		"node-gyp": "^12.3.0",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.1",
		"simple-git-hooks": "^2.13.1",
		"typescript": "catalog:"
	},
	"browserslist": {
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		],
		"production": [
			">=0.75%",
			"not dead",
			"not op_mini all"
		]
	},
	"commitlint": {
		"extends": "@acdh-oeaw/commitlint-config"
	},
	"prettier": "@acdh-oeaw/prettier-config",
	"simple-git-hooks": {
		"commit-msg": "pnpm exec commitlint --edit",
		"pre-commit": "pnpm exec lint-staged"
	},
	"lint-staged": {
		"*": "prettier --cache --ignore-unknown --write"
	},
	"dependencies": {}
}
