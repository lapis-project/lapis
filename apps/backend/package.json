{
	"name": "@lapis/backend",
	"private": true,
	"license": "MIT",
	"type": "module",
	"version": "1.0.0",
	"engines": {
		"node": ">=24.11.0",
		"pnpm": ">=10.25"
	},
	"exports": {
		"./api": {
			"types": "./src/app.ts"
		}
	},
	"scripts": {
		"dev": "tsx watch --env-file .env.local src/index.ts",
		"dev-test": "tsx watch src/index.ts",
		"generate-types-kysely": "kysely-codegen --default-schema=lapis_dev --include-pattern='lapis_dev.*' --env-file .env.local --dialect postgres --out-file src/types/db.d.ts",
		"test:cms-handler": "vitest cmsHandler",
		"test:article-handler": "vitest articleHandler",
		"test:user-handler": "vitest userHandler",
		"test:bib-handler": "vitest bibHandler",
		"start": "node --env-file .env.local ./dist/index.js",
		"build": "tsdown --dts && cp -r src/db/migrations dist/migrations",
		"migrate:latest": "NODE_OPTIONS='--import tsx' kysely migrate:latest -e local",
		"generate:noske": "openapi-typescript ./specs/openapi.yaml -o ./src/types/noske.d.ts"
	},
	"dependencies": {
		"@acdh-oeaw/lib": "^1.0.5",
		"@aws-sdk/client-s3": "^3.1000.0",
		"@aws-sdk/s3-request-presigner": "^3.1000.0",
		"@hono/node-server": "^1.19.10",
		"@hono/valibot-validator": "^0.6.1",
		"@imgproxy/imgproxy-node": "^1.1.0",
		"@node-rs/argon2": "^2.0.2",
		"dotenv": "^17.3.1",
		"hono": "^4.12.4",
		"kysely": "^0.28.14",
		"node-cron": "^4.2.1",
		"pg": "^8.20.0",
		"tsx": "^4.21.0",
		"valibot": "^1.3.1"
	},
	"devDependencies": {
		"@acdh-oeaw/eslint-config": "^2.0.13",
		"@acdh-oeaw/eslint-config-node": "^2.0.13",
		"@acdh-oeaw/prettier-config": "^2.0.1",
		"@acdh-oeaw/tsconfig": "^1.5.1",
		"@types/node": "^25.3.3",
		"@types/node-cron": "^3.0.11",
		"@types/pg": "^8.20.0",
		"@vitest/coverage-v8": "^4.1.1",
		"@vitest/ui": "^4.1.1",
		"eslint": "^9.39.2",
		"eslint-config-flat-gitignore": "^2.1.0",
		"kysely-codegen": "^0.20.0",
		"kysely-ctl": "^0.20.0",
		"openapi-typescript": "^7.13.0",
		"prettier": "^3.8.1",
		"tsdown": "0.21.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^8.0.2",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.1"
	},
	"eslintConfig": {
		"extends": [
			"@acdh-oeaw/eslint-config",
			"@acdh-oeaw/eslint-config/strict",
			"@acdh-oeaw/eslint-config-node"
		]
	},
	"lint-staged": {
		"*.@(js|ts)": [
			"eslint --cache --fix",
			"prettier --cache --write"
		]
	},
	"prettier": "@acdh-oeaw/prettier-config"
}
